<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="false">

    <!--
      환경별 값은 application.yml 에서 읽어옴 (<springProperty>).
      로그 파일 2종 분리 (파일명에 인스턴스명 포함 → 블루/그린 파일 충돌 없음):
        - app_{blue|green}.log    : INFO 이상 전체 (INFO/WARN/ERROR), 롤오버 시 .gz 압축
        - error_{blue|green}.log  : ERROR 만, 롤오버 시 .gz 압축
    -->

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty name="LOG_DIR"      source="app.log.dir"         defaultValue="/logs"/>
    <springProperty name="LOG_LEVEL"   source="app.log.level"       defaultValue="INFO"/>
    <springProperty name="LOG_HISTORY" source="app.log.max-history" defaultValue="30"/>
    <springProperty name="LOG_INSTANCE" source="log_instance"       defaultValue="app"/>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- ===== 콘솔 ===== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===== 전체 로그 파일 (INFO 이상 전부) ===== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/app_${LOG_INSTANCE}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/app_${LOG_INSTANCE}.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>${LOG_HISTORY}</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===== 에러 전용 파일 (ERROR 만) ===== -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/error_${LOG_INSTANCE}.log</file>
        <!-- ERROR 레벨만 통과, 나머지(INFO/WARN 등)는 DENY -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/error_${LOG_INSTANCE}.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>${LOG_HISTORY}</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===== 운영: 콘솔 + 전체파일 + 에러파일 ===== -->
    <springProfile name="dev,stg,prod">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

    <!-- ===== 로컬: 콘솔만 (파일도 원하면 FILE/ERROR_FILE 추가) ===== -->
    <springProfile name="local,default">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>